# ─── AWS ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
ECS_CLUSTER_NAME=impiricus-vibecode
ECR_REPO_NAME=impiricus-vibecode
LOG_GROUP_NAME=/ecs/impiricus-vibecode

# ─── ECS Task Defaults ───────────────────────────────────────────────────────
TASK_CPU=512
TASK_MEMORY=1024
DEFAULT_APP_PORT=8080

# ─── Fargate Networking ──────────────────────────────────────────────────────
FARGATE_SUBNETS=subnet-XXXXX,subnet-YYYYY
FARGATE_SECURITY_GROUP=sg-XXXXX
FARGATE_ASSIGN_PUBLIC_IP=ENABLED

# ─── IAM ─────────────────────────────────────────────────────────────────────
ECS_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/impiricus-ecs-execution

# ─── Secrets Manager Keys ────────────────────────────────────────────────────
# These are the SECRET NAMES in AWS Secrets Manager, not the actual values.
# Tangent fetches the real values from Secrets Manager at startup.
SECRET_NGROK_AUTHTOKEN=impiricus/ngrok-authtoken
SECRET_GITHUB_TOKEN=impiricus/devops-agent-github-token
SECRET_ANTHROPIC_KEY=impiricus/devops-agent-anthropic-key
SECRET_SLACK_APP_TOKEN=impiricus/devops-agent-slack-app-token
SECRET_SLACK_TOKEN=impiricus/devops-agent-slack-token

# ─── Slack ───────────────────────────────────────────────────────────────────
SLACK_CHANNEL=#ai-engineering
# Comma-separated Slack member IDs allowed to control Tangent.
# Find via: profile → ⋮ → Copy member ID (starts with U or W).
# Leave blank to allow everyone.
ALLOWED_SLACK_USER_IDS=U012AB3CD,U098ZY7WX

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_ORG=impiricus
SCAFFOLD_CHILD_TOPIC=impiricus-scaffold-child

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1

# ─── Workspace ───────────────────────────────────────────────────────────────
# Temporary directory for git clones and docker builds.
# Cleaned up after each build.
WORKSPACE_DIR=/home/ubuntu/tangent-workspace
